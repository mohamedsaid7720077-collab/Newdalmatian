import os
import subprocess
import threading
import json
import http.server
import socketserver
import cgi
import shutil
import logging
from pydub import AudioSegment
from docx import Document

# --- CONFIGURATION ---
PORT = 8000
CHUNK_MINUTES = 10
MODEL_PATH = "whisper.cpp/models/ggml-base.bin"
WHISPER_EXE = "./whisper.cpp/main"

# Global state for tracking progress
progress = {"status": "idle", "percent": 0, "file_ready": False}

# Ensure required directories exist
for folder in ["uploads", "chunks", "output"]:
    if not os.path.exists(folder):
        os.makedirs(folder, exist_ok=True)

# Setup logging
logging.basicConfig(level=logging.INFO, format="%(asctime)s [%(levelname)s] %(message)s")

HTML_PAGE = """
