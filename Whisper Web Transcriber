import os
import subprocess
import threading
import json
from http.server import BaseHTTPRequestHandler, HTTPServer
import cgi
from pydub import AudioSegment
from docx import Document

PORT = 8000
CHUNK_MINUTES = 10
MODEL_PATH = "whisper.cpp/models/ggml-base.bin"

progress = {"status": "idle", "percent": 0}

for folder in ["uploads", "chunks", "output"]:
    os.makedirs(folder, exist_ok=True)

HTML_PAGE = """
<!DOCTYPE html>
<html>
<head>

<title>Whisper Web Transcriber</title>

<style>

body{
font-family:Arial;
background:#f4f6f8;
padding:40px
