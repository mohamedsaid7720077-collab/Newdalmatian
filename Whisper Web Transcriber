def process_audio(filepath):
    global progress
    try:
        logging.info("Starting processing for %s", filepath)
        # 1. Splitting & Normalizing
        progress.update({"status": "Converting & Splitting...", "percent": 5})
        audio = AudioSegment.from_file(filepath)
        audio = audio.set_frame_rate(16000).set_channels(1)  # Crucial for whisper.cpp

        chunk_length = CHUNK_MINUTES * 60 * 1000
        chunks = []
        for i, start in enumerate(range(0, len(audio), chunk_length)):
            chunk_path = f"chunks/chunk_{i}.wav"
            audio[start:start+chunk_length].export(chunk_path, format="wav")
            chunks.append(chunk_path)

        # 2. Transcribing
        full_text = ""
        for i, chunk in enumerate(chunks):
            progress["status"] = f"Transcribing part {i+1}/{len(chunks)}..."
            progress["percent"] = 10 + int((i / max(1, len(chunks))) * 80)

            cmd = [WHISPER_EXE, "-m", MODEL_PATH, "-f", chunk, "-nt"]
            logging.info("Running whisper: %s", " ".join(cmd))
            res = subprocess.run(cmd, capture_output=True, text=True, encoding='utf-8')
            if res.returncode != 0:
                logging.error("Whisper failed for %s: %s", chunk, res.stderr)
                raise RuntimeError(f"Whisper failed: {res.stderr.strip()}")
            full_text += res.stdout + "\n"
            try:
                os.remove(chunk)  # Cleanup chunk file
            except Exception:
                logging.warning("Failed to remove chunk %s", chunk)

        # 3. Exporting
        progress["status"] = "Generating files..."
        with open("output/result.txt", "w", encoding="utf-8") as f:
            f.write(full_text)

        doc = Document()
        doc.add_heading('Transcription Export', 0)
        doc.add_paragraph(full_text)
        doc.save("output/result.docx")

        progress.update({"status": "finished", "percent": 100, "file_ready": True})
        logging.info("Processing finished for %s", filepath)
    except Exception as e:
        logging.exception("Processing failed")
        progress.update({"status": f"Error: {str(e)}", "percent": 0})
    finally:
        # Remove the uploaded file to avoid storage growth
        try:
            if os.path.exists(filepath):
                os.remove(filepath)
                logging.info("Removed uploaded file %s", filepath)
        except Exception:
            logging.warning("Could not remove uploaded file %s", filepath)

class CustomHandler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path == "/":
            self.send_response(200)
            self.send_header("Content-type", "text/html; charset=utf-8")
            self.end_headers()
            self.wfile.write(HTML_PAGE.encode())
        elif self.path == "/progress":
            self.send_response(200)
            self.send_header("Content-type", "application/json")
            self.end_headers()
            self.wfile.write(json.dumps(progress).encode())
        elif self.path.startswith("/output/"):
            file_path = self.path.lstrip("/")
            if os.path.exists(file_path):
                self.send_response(200)
                # Set appropriate content-type and attachment header
                if file_path.endswith(".txt"):
                    self.send_header("Content-type", "text/plain; charset=utf-8")
                    disposition_name = "result.txt"
                elif file_path.endswith(".docx"):
                    self.send_header("Content-type", "application/vnd.openxmlformats-officedocument.wordprocessingml.document")
                    disposition_name = "result.docx"
                else:
                    self.send_header("Content-type", "application/octet-stream")
                    disposition_name = os.path.basename(file_path)
                self.send_header("Content-Disposition", f'attachment; filename="{disposition_name}"')
                self.end_headers()
                with open(file_path, "rb") as f:
                    self.wfile.write(f.read())
            else:
                self.send_error(404)
        else:
            self.send_error(404)

    def do_POST(self):
        # Build a proper environ for cgi.FieldStorage so CONTENT_LENGTH is known
        try:
            ctype = self.headers.get('Content-Type')
            clen = self.headers.get('Content-Length', '0')
            environ = {
                'REQUEST_METHOD': 'POST',
                'CONTENT_TYPE': ctype,
                'CONTENT_LENGTH': clen
            }
            form = cgi.FieldStorage(fp=self.rfile, headers=self.headers, environ=environ)

            if "file" in form:
                file_item = form["file"]
                raw_filename = getattr(file_item, 'filename', None)
                if not raw_filename:
                    self.send_error(400, "No filename provided")
                    return
                secure_name = os.path.basename(raw_filename)
                # Basic sanitize: remove path separators and control chars
                secure_name = secure_name.replace("/", "_").replace("\\", "_")
                file_path = os.path.join("uploads", secure_name)

                with open(file_path, "wb") as f:
                    # file_item.file might be a binary file-like
                    shutil.copyfileobj(file_item.file, f)

                # Reset progress and start thread
                global progress
                progress = {"status": "Starting...", "percent": 0, "file_ready": False}
                t = threading.Thread(target=process_audio, args=(file_path,))
                t.daemon = True
                t.start()

                self.send_response(200)
                self.send_header("Content-type", "text/html; charset=utf-8")
                self.end_headers()
                self.wfile.write(b"Processing started")
            else:
                self.send_error(400, "No file field in form")
        except Exception as e:
            logging.exception("Failed handling POST")
            self.send_error(500, f"Server error: {e}")

if __name__ == "__main__":
    logging.info("Server live at http://localhost:%s", PORT)
    # Use a threaded server so multiple clients can query progress concurrently
    with socketserver.ThreadingTCPServer(("", PORT), CustomHandler) as httpd:
        try:
            httpd.serve_forever()
        except KeyboardInterrupt:
            logging.info("Shutting down server")
            httpd.shutdown()
